# Use Node
FROM node:18-alpine

WORKDIR /app

# Install deps
COPY package*.json ./
RUN npm ci

# Copy project
COPY . .

# Build (if using TypeScript)
RUN npm run build

# Expose port
EXPOSE 3000

# Start: run migrations THEN start app
CMD ["sh", "-c", "npm run db:push && node dist/index.js"]